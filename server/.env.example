# ── AI Provider ──
# Options: openai, fiqstr-plus, fiqstr-premium, together, groq, openrouter, custom
AI_PROVIDER=openai

# API key (use OPENAI_API_KEY for OpenAI, or AI_API_KEY for any provider)
OPENAI_API_KEY=sk-...
# OR for non-OpenAI providers:
# AI_API_KEY=your-key-here

# Model override (leave empty to use provider default)
AI_MODEL=

# Custom base URL (only needed for "custom" provider)
AI_BASE_URL=

# Fiqstr package selector (only used when AI_PROVIDER=fiqstr-plus or fiqstr-premium)
# AI_FIQSTR_PACKAGE=premium   # premium | plus

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_pro_monthly_id
STRIPE_PRICE_BUSINESS=price_business_monthly_id

# ── App ──
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
