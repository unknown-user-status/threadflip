<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFBFE">

    <!-- Modern Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_header_gradient">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SmartWriter AI"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Content Generator"
                android:textSize="13sp"
                android:textColor="#EADDFF" />
        </LinearLayout>

        <Button
            android:id="@+id/supportBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="⭐"
            android:textSize="18sp"
            android:background="@drawable/bg_card_modern"
            android:gravity="center"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/settingsBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="⚙"
            android:textSize="20sp"
            android:background="@drawable/bg_card_modern"
            android:gravity="center" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- Status Row: Provider + Limit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:padding="12dp">

                <TextView
                    android:id="@+id/providerIndicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#625B71" />

                <TextView
                    android:id="@+id/limitCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#6750A4"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Content Type Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What do you want to create?"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1C1B1F"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/contentTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:chipSpacing="8dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipBackgroundColor="#F5F3F7"
                app:chipStrokeColor="#E7E0EC"
                app:checkedChipBackgroundColor="#6750A4"
                app:checkedChipTextColor="#FFFFFF" />

            <!-- Input Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Describe your idea"
                android:textSize="14sp"
                android:textColor="#625B71"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                android:hint="e.g. Luxury condo in KLCC area...">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:maxLines="5"
                    android:inputType="textMultiLine"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Generate Button -->
            <Button
                android:id="@+id/generateBtn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="✨  Generate Content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_gradient"
                android:stateListAnimator="@null"
                android:elevation="2dp"
                android:layout_marginBottom="16dp" />

            <!-- Progress -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                android:indeterminate="true"
                app:indicatorColor="#7C4DFF"
                app:trackColor="#EADDFF" />

            <!-- Modern Result Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="16dp"
                android:translationZ="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Result Header with type badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:id="@+id/resultTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Generated Content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1C1B1F" />

                        <Button
                            android:id="@+id/viewFullBtn"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:text="↗"
                            android:textSize="16sp"
                            android:background="@drawable/bg_input"
                            android:gravity="center"
                            android:contentDescription="View Full" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0EEF3" />

                    <!-- Result Text Area -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="280dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:id="@+id/resultText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#1C1B1F"
                            android:lineSpacingExtra="6dp"
                            android:textIsSelectable="true" />

                    </ScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0EEF3" />

                    <!-- Bottom Action Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="8dp"
                        android:background="#FAF9FB">

                        <Button
                            android:id="@+id/copyBtn"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="📋  Copy"
                            android:textSize="13sp"
                            android:background="@android:color/transparent"
                            android:textColor="#6750A4"
                            android:foreground="?attr/selectableItemBackground"
                            style="@style/Widget.AppCompat.Button.Borderless" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="28dp"
                            android:background="#E7E0EC" />

                        <Button
                            android:id="@+id/shareBtn"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="📤  Share"
                            android:textSize="13sp"
                            android:background="@android:color/transparent"
                            android:textColor="#6750A4"
                            android:foreground="?attr/selectableItemBackground"
                            style="@style/Widget.AppCompat.Button.Borderless" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom History Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:background="@android:color/white"
        android:elevation="8dp">

        <Button
            android:id="@+id/historyBtn"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="📜  Generation History"
            android:textSize="14sp"
            android:textColor="#6750A4"
            android:background="@android:color/transparent"
            style="@style/Widget.AppCompat.Button.Borderless" />

    </LinearLayout>

</LinearLayout>
