<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp" app:cardCornerRadius="14dp" app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:id="@+id/typeText" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#6750A4" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
            <TextView android:id="@+id/timestampText" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp" android:textColor="#625B71" />
        </LinearLayout>
        <TextView android:id="@+id/inputText" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#625B71"
            android:layout_marginBottom="6dp" />
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F0EEF3" android:layout_marginVertical="6dp" />
        <TextView android:id="@+id/outputText" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1C1B1F"
            android:maxLines="4" android:lineSpacingExtra="4dp" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="end">
            <Button android:id="@+id/copyBtn" android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Copy" android:textSize="12sp" android:textColor="#6750A4"
                android:background="@android:color/transparent"
                style="@style/Widget.AppCompat.Button.Borderless" />
            <Button android:id="@+id/shareBtn" android:layout_width="wrap_content" android:layout_height="30dp"
                android:text="Share" android:textSize="12sp" android:textColor="#6750A4"
                android:background="@android:color/transparent"
                style="@style/Widget.AppCompat.Button.Borderless" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
